{
    "meta": {
       "domain": "realEstate",
        "version": "0.1.0",
        "description": "Domain vocabulary for real estate properties and related actions."
    },
    "extends": [
        "identity"
    ],
    "entities": {
        "property": {
            "description": "A real estate property such as a house, apartment, or commercial building.",
            "identifiers": {
                "propertyId": {
                    "type": "string",
                    "required": true,
                    "description": "Canonical property identifier."
                }
            }
        },
        "listing": {
            "description": "A listing of a property for sale or rent.",
            "extends": [
                "property"
            ],
            "identifiers": {
                "listingId": {
                    "type": "string",
                    "required": true,
                    "description": "Canonical listing identifier."
                }
            }
        },
        "agency": {
            "description": "A real estate agency or brokerage.",
            "extends": [
                "subject"
            ],
            "identifiers": {
                "agencyId": {
                    "type": "string",
                    "required": true,
                    "description": "Canonical agency identifier."
                }
            }
        },
        "office": {
            "description": "A real estate office location.",
            "extends": [
                "subject"
            ],
            "identifiers": {
                "officeId": {
                    "type": "string",
                    "required": true,
                    "description": "Canonical office identifier."
                }
            }
        },
        "appraisal": {
            "description": "A property appraisal.",
            "identifiers": {
                "appraisalId": {
                    "type": "string",
                    "required": false,
                    "description": "Canonical appraisal identifier."
                }
            },
            "actions": {
                "requested": {
                    "description": "An appraisal was requested.",
                    "performedBy": [
                        "subject"
                    ]
                }
            }
        }
        
    }
}
